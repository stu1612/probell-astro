---
import { Image } from 'astro:assets';
import TornEdge from '@components/ui/TornEdge.astro';
---

<section class="hero">
  <Image
    src="/images/hero/hero-main.png"
    alt="Probell Nutrition athlete in training"
    width={1920}
    height={1080}
    format="webp"
    loading="eager"
    class="hero__image"
  />
  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="headline headline--active display-text">Built for the Grind.</h1>
    <h1 class="headline display-text">The Only Protein You Can Actually Lift.</h1>
    <h1 class="headline display-text">No Days Off.</h1>
    <h1 class="headline display-text">Fuel the Grind.</h1>
    <p class="label-text hero__subline">Probell Nutrition. Coming soon.</p>
    <a href="/#contact" class="btn-primary hero__cta">Join the Waitlist</a>
  </div>
  <TornEdge fill="var(--color-black)" />
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    overflow: hidden;
    margin-top: calc(-1 * var(--nav-height));
  }

  .hero__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
  }

  .hero__content {
    position: absolute;
    top: 50%;
    right: var(--space-md);
    transform: translateY(-50%);
    max-width: 800px;
    z-index: 2;
  }

  .headline {
    font-family: var(--font-display);
    font-size: var(--text-hero);
    color: var(--color-white);
    display: none;
  }

  .headline--active {
    display: block;
  }

  .hero__subline {
    margin-top: var(--space-sm);
  }

  .hero__cta {
    margin-top: var(--space-md);
  }

  @media (max-width: 768px) {
    .hero__image {
      object-position: 10% 50%;
    }

    .hero__content {
      top: auto;
      bottom: var(--space-lg);
      right: var(--space-sm);
      left: var(--space-sm);
      transform: none;
      max-width: 100%;
    }
  }
</style>
