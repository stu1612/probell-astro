---
import { Image } from 'astro:assets';

const products = [
  {
    image: '/images/trending/trending-strawberry.png',
    alt: 'Probell Whey Strawberry',
    name: 'Whey Strawberry',
    descriptor: '25g protein. Blue collar formula.',
    tag: 'Whey Protein'
  },
  {
    image: '/images/trending/trending-chocolate.png',
    alt: 'Probell Whey Cookies & Cream',
    name: 'Whey Cookies & Cream',
    descriptor: '25g protein. No days off formula.',
    tag: 'Whey Protein'
  },
  {
    image: '/images/trending/trending-pineapple.png',
    alt: 'Probell Creatine',
    name: 'Creatine',
    descriptor: 'Micronised creatine. Maximum absorption.',
    tag: 'Creatine'
  },
];
---

<section id="trending" class="trending">
  <div class="container">
    <div class="trending__header">
      <span class="label-text label-text--red">Performance Series</span>
      <h2 class="trending__heading display-text">Trending</h2>
    </div>
    <div class="trending-grid">
      {products.map((product) => (
        <article class="product-card">
          <div class="product-card__image-wrap">
            <Image
              src={product.image}
              alt={product.alt}
              width={600}
              height={800}
              format="webp"
              loading="lazy"
            />
          </div>
          <div class="product-card__content">
            <span class="tag tag--coming-soon">{product.tag}</span>
            <h3 class="product-card__name">{product.name}</h3>
            <p class="product-card__descriptor">{product.descriptor}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .trending {
    background: var(--color-bg-warm);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .trending__header {
    margin-bottom: var(--space-md);
  }

  .trending__heading {
    font-size: var(--text-section);
    color: var(--color-black);
    margin: var(--space-xs) 0 0;
  }

  .trending-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .product-card {
    background: transparent;
    border: none;
  }

  .product-card__image-wrap {
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    border-radius: 4px;
  }

  .product-card__image-wrap :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .product-card__image-wrap :global(img:hover) {
    transform: scale(1.03);
  }

  .product-card__content {
    padding: var(--space-sm) 0;
  }

  .product-card__name {
    font-family: var(--font-display);
    font-size: var(--text-product);
    color: var(--color-black);
    margin: var(--space-xs) 0 0;
    text-transform: uppercase;
  }

  .product-card__descriptor {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-border);
    margin: var(--space-xs) 0 0;
  }

  @media (max-width: 767px) {
    .trending-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
