---
import { Image } from 'astro:assets';

interface Props {
  image?: string;
  imageAlt?: string;
  name: string;
  descriptor: string;
  tag?: string;
  large?: boolean;
}

const { image, imageAlt = '', name, descriptor, tag, large = false } = Astro.props;
---

<div class={`product-card${large ? ' product-card--large' : ''}`}>
  {image ? (
    <Image
      src={image}
      alt={imageAlt}
      width={600}
      height={600}
      format="webp"
      loading="lazy"
      class="product-card__image"
    />
  ) : (
    <div class="product-card__image"></div>
  )}
  <div class="product-card__content">
    {tag && <span class="tag tag--coming-soon">{tag}</span>}
    <p class="product-card__name">{name}</p>
    <p class="product-card__descriptor">{descriptor}</p>
  </div>
</div>
