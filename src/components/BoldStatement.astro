---
import { Image } from 'astro:assets';
import TornEdge from '@components/ui/TornEdge.astro';
---

<section class="bold-statement" id="bold-statement">
  <Image
    src="/images/bold-statement/discipline.png"
    alt=""
    width={1440}
    height={900}
    format="webp"
    loading="lazy"
    class="bold-statement__image"
  />
  <div class="bold-statement__overlay"></div>
  <div class="bold-statement__content">
    <h2 class="display-text bold-statement__headline">
      You Already Know Why You're Here.
    </h2>
  </div>
  <TornEdge fill="var(--color-black)" />
</section>

<style>
  .bold-statement {
    position: relative;
    height: 100vh;
    overflow: hidden;
  }

  .bold-statement__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .bold-statement__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
  }

  .bold-statement__content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    width: 100%;
    padding: 0 var(--space-md);
  }

  .bold-statement__headline {
    font-size: var(--text-statement);
    color: var(--color-white);
    max-width: 900px;
    margin: 0 auto;
  }
</style>
