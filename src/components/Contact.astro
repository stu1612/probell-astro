---
const web3formsKey = import.meta.env.WEB3FORMS_KEY ?? '';
---

<section id="contact" class="section section--lg" style={`background: var(--color-surface);`}>
  <div class="container">
    <div class="contact-grid">

      <div class="contact-content">
        <span class="label-text label-text--red">Partner with Probell</span>
        <h2 class="display-text contact-headline">
          Stock Probell.<br />Be First.
        </h2>
        <p class="contact-subline">
          Whether you&rsquo;re a gym, distributor, or retailer &mdash;
          we want to hear from you.
        </p>
      </div>

      <div class="contact-form-wrap">
        <div
          id="contact-success"
          class="contact-success label-text"
          style="display: none;"
          aria-live="polite"
        >
          Thanks for reaching out. We&rsquo;ll be in touch soon.
        </div>

        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          novalidate
        >
          <input type="hidden" name="access_key" value={web3formsKey} />
          <input type="hidden" name="subject" value="New Probell Partnership Enquiry" />
          <input type="hidden" name="redirect" value="false" />
          <input type="checkbox" name="botcheck" style="display: none;" />

          <div class="form-group">
            <label class="form-label" for="contact-name">Full Name</label>
            <input
              class="form-input"
              type="text"
              id="contact-name"
              name="name"
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-business">Business Name</label>
            <input
              class="form-input"
              type="text"
              id="contact-business"
              name="business"
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-email">Email Address</label>
            <input
              class="form-input"
              type="email"
              id="contact-email"
              name="email"
              required
            />
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-type">I am a&hellip;</label>
            <select
              class="form-select"
              id="contact-type"
              name="type"
              required
            >
              <option value="" disabled selected></option>
              <option value="Gym">Gym</option>
              <option value="Distributor">Distributor</option>
              <option value="Retailer">Retailer</option>
              <option value="Other">Other</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="contact-message">Message</label>
            <textarea
              class="form-textarea"
              id="contact-message"
              name="message"
              placeholder="Tell us about your business and how you'd like to work with Probell."
            ></textarea>
          </div>

          <div class="h-captcha" data-captcha="true"></div>

          <p
            id="contact-error"
            class="contact-error label-text"
            style="display: none;"
            aria-live="polite"
          >
            Something went wrong. Please try again or email us directly.
          </p>

          <button type="submit" class="btn-primary contact-submit">
            Get in Touch
          </button>
        </form>
      </div>

    </div>
  </div>
</section>

<script src="https://web3forms.com/client/script.js" async defer></script>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('contact-success');
  const error = document.getElementById('contact-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !success || !error) return;

    error.style.display = 'none';

    const data = new FormData(form);

    try {
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });
      const json = await res.json();

      if (json.success) {
        form.style.display = 'none';
        success.style.display = 'block';
      } else {
        error.style.display = 'block';
      }
    } catch {
      error.style.display = 'block';
    }
  });
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .contact-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-headline {
    font-size: var(--text-section);
    color: var(--color-white);
    margin: 0;
  }

  .contact-subline {
    font-family: var(--font-body);
    font-size: var(--text-body);
    color: var(--color-grey);
    line-height: 1.6;
    margin: 0;
  }

  .contact-success {
    color: var(--color-gold);
    padding: var(--space-lg) 0;
  }

  .contact-error {
    color: var(--color-red);
    margin-bottom: var(--space-sm);
  }

  .contact-submit {
    margin-top: var(--space-sm);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .contact-submit {
      width: 100%;
    }
  }
</style>
