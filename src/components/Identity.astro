<section id="identity">
  <div class="identity-container">
    <p class="display-text identity-line-1">Fuel for people who already show up.</p>
    <p class="display-text identity-line-2">No shortcuts. No fillers. No compromise.</p>
  </div>
</section>

<style>
  #identity {
    background: var(--color-black);
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-xl);
  }

  .identity-container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .identity-line-1 {
    font-family: var(--font-display);
    font-size: var(--text-statement);
    color: var(--color-white);
    line-height: 0.95;
    margin: 0;
  }

  .identity-line-2 {
    font-family: var(--font-display);
    font-size: var(--text-section);
    color: var(--color-red);
    line-height: 0.95;
    margin: 0;
    margin-top: var(--space-sm);
  }
</style>
