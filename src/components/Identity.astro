---
interface Props {
  headline: string;
  body: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
}

const { headline, body, primaryCta, secondaryCta } = Astro.props;
const hasCtas = primaryCta || secondaryCta;
---

<section id="identity">
  <div class="identity__row1">
    <div class="identity__left">
      <h4 class="display-text identity__headline">{headline}</h4>
      {hasCtas && (
        <div class="identity__ctas">
          {primaryCta && <a href={primaryCta.href} class="btn-primary">{primaryCta.label}</a>}
          {secondaryCta && <a href={secondaryCta.href} class="btn-secondary">{secondaryCta.label}</a>}
        </div>
      )}
    </div>
    <div class="identity__body">
      <p class="identity__body-text">{body}</p>
    </div>
  </div>
</section>

<style>
  #identity {
    padding: var(--space-md) 0;
  }

  .identity__row1 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .identity__left {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    justify-content: space-between;
    height: 100%;
  }

  .identity__headline {
    font-family: var(--font-display);
    font-size: var(--text-statement);
    color: var(--color-black);
  }

  .identity__body {
    background: var(--color-black);
    height: 100%;
    padding: var(--space-lg);
    border-radius: var(--radius-image);

  }

  .identity__body-text {
    font-size: 20px;
    color: var(--color-white);
    line-height: 1.6;
  }

  .identity__ctas {
    display: flex;
    gap: var(--space-md);
  }

    @media (max-width: 1040px) {
    .identity__row1 {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .identity__ctas {
      flex-direction: column;
      align-items: flex-start;
    }
  }


